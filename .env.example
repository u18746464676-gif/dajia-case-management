# 火山引擎 TOS 配置（复制并改名为 .env.local 后填写）
VITE_TOS_BUCKET=你的桶名称
VITE_TOS_REGION=你的地域
VITE_TOS_ENDPOINT=你的Endpoint
VITE_TOS_ACCESS_KEY_ID=你的AK
VITE_TOS_SECRET_ACCESS_KEY=你的SK

# 推荐：走服务端存储网关，前端不再直连 TOS
VITE_STORAGE_API_BASE=http://127.0.0.1:8787

# 服务端可复用同一套配置，也支持改成不带 VITE_ 前缀的环境变量
# TOS_BUCKET=
# TOS_REGION=
# TOS_ENDPOINT=
# TOS_ACCESS_KEY_ID=
# TOS_SECRET_ACCESS_KEY=
# STORAGE_SERVER_PORT=8787
# STORAGE_ALLOWED_ORIGIN=http://127.0.0.1:3000